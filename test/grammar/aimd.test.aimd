// SYNTAX TEST "source.aimd" "aimd var with type syntax"

// Simple type annotation
{{var|name: str}}
//<- punctuation.definition.begin.aimd
//^^^ keyword.variable.aimd
//   ^ delimiter.pipe.aimd
//    ^^^^ variable.other.aimd
//        ^ delimiter.colon.aimd
//          ^^^ support.type.aimd
//             ^^ punctuation.definition.end.aimd

// Type with default value
{{var|age: int = 18}}
//<- punctuation.definition.begin.aimd
//^^^ keyword.variable.aimd
//   ^ delimiter.pipe.aimd
//    ^^^ variable.other.aimd
//       ^ delimiter.colon.aimd
//         ^^^ support.type.aimd
//             ^ delimiter.parameter.aimd
//               ^^ constant.numeric.aimd
//                 ^^ punctuation.definition.end.aimd

// Type with string default and kwargs
{{var|name: str = "张三", title = "姓名", max_length = 50}}
//<- punctuation.definition.begin.aimd
//^^^ keyword.variable.aimd
//   ^ delimiter.pipe.aimd
//    ^^^^ variable.other.aimd
//        ^ delimiter.colon.aimd
//          ^^^ support.type.aimd
//              ^ delimiter.parameter.aimd
//                ^^^^ string.quoted.aimd
//                    ^ delimiter.parameter.aimd
//                      ^^^^^ variable.other.aimd
//                            ^ delimiter.parameter.aimd
//                              ^^^^ string.quoted.aimd

// Boolean type with boolean default
{{var|active: bool = true}}
//<- punctuation.definition.begin.aimd
//^^^ keyword.variable.aimd
//   ^ delimiter.pipe.aimd
//    ^^^^^^ variable.other.aimd
//          ^ delimiter.colon.aimd
//            ^^^^ support.type.aimd
//                 ^ delimiter.parameter.aimd
//                   ^^^^ constant.language.aimd
//                       ^^ punctuation.definition.end.aimd

// List type with subvars
{{var|students: list[Student], subvars=[name: str, age: int]}}
//<- punctuation.definition.begin.aimd
//^^^ keyword.variable.aimd
//   ^ delimiter.pipe.aimd
//    ^^^^^^^^ variable.other.aimd
//            ^ delimiter.colon.aimd
//              ^^^^^^^^^^^^^ support.type.aimd
//                           ^ delimiter.parameter.aimd
//                             ^^^^^^^ keyword.other.subvars.aimd
//                                    ^ delimiter.parameter.aimd
//                                     ^ delimiter.bracket.aimd
//                                      ^^^^ variable.other.aimd
//                                          ^ delimiter.colon.aimd
//                                            ^^^ support.type.aimd

// SYNTAX TEST "source.aimd" "aimd var_table with type syntax"

// var_table with nested var() subvars
{{var_table|items: list[Item], subvars=[var(id: str), var(count: int = 0)]}}
//<- punctuation.definition.begin.aimd
//^^^^^^^^^ keyword.variable-table.aimd
//         ^ delimiter.pipe.aimd
//          ^^^^^ variable.other.aimd
//               ^ delimiter.colon.aimd
//                 ^^^^^^^^^^ support.type.aimd
//                           ^ delimiter.parameter.aimd
//                             ^^^^^^^ keyword.other.subvars.aimd
//                                    ^ delimiter.parameter.aimd
//                                     ^ delimiter.bracket.aimd
//                                      ^^^ keyword.variable.aimd