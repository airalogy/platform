{
  "name": "aimd",
  "scopeName": "source.aimd",
  "fileTypes": [".aimd", ".md"],
  "injectTo": ["text.html.markdown"],
  "injectionSelector": "L:text.html.markdown",
  "patterns": [
    {
      "include": "#aimd-variable"
    },
    {
      "include": "#aimd-variable-table"
    },
    {
      "include": "#aimd-checkpoint"
    },
    {
      "include": "#aimd-step"
    },
    {
      "include": "#aimd-references"
    }
  ],
  "repository": {
    "aimd-variable": {
      "begin": "({{)\\s*(var)\\s*(\\|)",
      "end": "(}})",
      "name": "markup.aimd.variable",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.begin.aimd"
        },
        "2": {
          "name": "keyword.variable.aimd"
        },
        "3": {
          "name": "delimiter.pipe.aimd"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.end.aimd"
        }
      },
      "patterns": [
        {
          "include": "#aimd-type-content"
        }
      ]
    },
    "aimd-variable-table": {
      "begin": "({{)\\s*(var_table)\\s*(\\|)",
      "end": "(}})",
      "name": "markup.aimd.variable-table",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.begin.aimd"
        },
        "2": {
          "name": "keyword.variable-table.aimd"
        },
        "3": {
          "name": "delimiter.pipe.aimd"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.end.aimd"
        }
      },
      "patterns": [
        {
          "include": "#aimd-type-content"
        }
      ]
    },
    "aimd-checkpoint": {
      "match": "({{)\\s*(check)\\s*(\\|)\\s*([^}]+?)\\s*(}})",
      "name": "markup.aimd.checkpoint",
      "captures": {
        "1": {
          "name": "punctuation.definition.begin.aimd"
        },
        "2": {
          "name": "keyword.checkpoint.aimd"
        },
        "3": {
          "name": "delimiter.pipe.aimd"
        },
        "4": {
          "name": "variable.parameter.aimd"
        },
        "5": {
          "name": "punctuation.definition.end.aimd"
        }
      }
    },
    "aimd-step": {
      "match": "({{)\\s*(step)\\s*(\\|)\\s*([^}]+?)\\s*(}})",
      "name": "markup.aimd.step",
      "captures": {
        "1": {
          "name": "punctuation.definition.begin.aimd"
        },
        "2": {
          "name": "keyword.step.aimd"
        },
        "3": {
          "name": "delimiter.pipe.aimd"
        },
        "4": {
          "name": "variable.parameter.aimd"
        },
        "5": {
          "name": "punctuation.definition.end.aimd"
        }
      }
    },
    "aimd-references": {
      "patterns": [
        {
          "match": "({{)\\s*(ref_step)\\s*(\\|)\\s*([^}]+?)\\s*(}})",
          "name": "markup.aimd.reference.step",
          "captures": {
            "1": {
              "name": "punctuation.definition.begin.aimd"
            },
            "2": {
              "name": "keyword.reference.step.aimd"
            },
            "3": {
              "name": "delimiter.pipe.aimd"
            },
            "4": {
              "name": "variable.parameter.aimd"
            },
            "5": {
              "name": "punctuation.definition.end.aimd"
            }
          }
        },
        {
          "match": "({{)\\s*(ref_var)\\s*(\\|)\\s*([^}]+?)\\s*(}})",
          "name": "markup.aimd.reference.variable",
          "captures": {
            "1": {
              "name": "punctuation.definition.begin.aimd"
            },
            "2": {
              "name": "keyword.reference.variable.aimd"
            },
            "3": {
              "name": "delimiter.pipe.aimd"
            },
            "4": {
              "name": "variable.parameter.aimd"
            },
            "5": {
              "name": "punctuation.definition.end.aimd"
            }
          }
        }
      ]
    },
    "aimd-type-content": {
      "patterns": [
        {
          "match": "(:)\\s*([\\w_]+(?:\\[[\\w_,\\s]+\\])?)",
          "captures": {
            "1": {
              "name": "delimiter.colon.aimd"
            },
            "2": {
              "name": "support.type.aimd"
            }
          }
        },
        {
          "match": "\"([^\"\\\\]|\\\\.)*\"",
          "name": "string.quoted.aimd"
        },
        {
          "match": "'([^'\\\\]|\\\\.)*'",
          "name": "string.quoted.aimd"
        },
        {
          "match": "-?\\d+\\.?\\d*",
          "name": "constant.numeric.aimd"
        },
        {
          "match": "\\b(true|false|True|False|null|None)\\b",
          "name": "constant.language.aimd"
        },
        {
          "match": "\\bsubvars\\b",
          "name": "keyword.other.subvars.aimd"
        },
        {
          "match": "\\bvar\\b",
          "name": "keyword.variable.aimd"
        },
        {
          "match": "=",
          "name": "delimiter.parameter.aimd"
        },
        {
          "match": ",",
          "name": "delimiter.parameter.aimd"
        },
        {
          "match": "[\\[\\]()]",
          "name": "delimiter.bracket.aimd"
        },
        {
          "match": "\\b[\\w_]+\\b",
          "name": "variable.other.aimd"
        }
      ]
    }
  }
}
