# Airalogy Platform Community frontend example

VITE_BASE_URL=/
VITE_APP_TITLE=Airalogy Platform
VITE_APP_DESC=Self-hosted research data, protocols, records, and AI-assisted scientific workflows.

# dev uses the local backend through Vite proxy by default.
VITE_SERVICE_ENV=dev
VITE_HTTP_PROXY=Y
VITE_API_BASE_URL=http://127.0.0.1:4000
VITE_MINIO_BASE_URL=http://127.0.0.1:9200
VITE_DEMO_BASE_URL=http://127.0.0.1:9528
VITE_SITE_ORIGIN=http://localhost:3000
VITE_DOCS_URL=https://github.com/airalogy/platform/tree/main/docs

# Optional China mainland compliance footer.
# Keep disabled for the Community Edition default. Enable only for deployments
# that legally use the configured ICP and public-security registration records.
VITE_CHINA_COMPLIANCE_FOOTER=N
# VITE_ICP_RECORD_NUMBER=浙ICP备2025159537号-1
# VITE_ICP_RECORD_URL=https://beian.miit.gov.cn/
# VITE_POLICE_RECORD_NUMBER=浙公网安备33010602013955号
# VITE_POLICE_RECORD_CODE=33010602013955
# VITE_POLICE_RECORD_URL="https://beian.mps.gov.cn/#/query/webSearch?code=33010602013955"
# VITE_POLICE_RECORD_ICON_URL=

VITE_ROUTER_HISTORY_MODE=history
VITE_AUTH_ROUTE_MODE=static
VITE_ROUTE_HOME=home

VITE_ICON_PREFIX=icon
VITE_ICON_LOCAL_PREFIX=icon-local
VITE_ICON_SHARED_PREFIX=icon-shared
VITE_MENU_ICON=mdi:menu

VITE_OSS_BASE=/minio
VITE_SOURCE_MAP=N
VITE_APP_ARMS_ENABLE=N
VITE_RUM_PID=
VITE_RUM_ENDPOINT=
VITE_GA_ID=
VITE_RECORD_DELETE_GRACE_DAYS=7

# Set to Y only if you want vite-plugin-mkcert to generate local HTTPS certs.
VITE_MKCERT=N
