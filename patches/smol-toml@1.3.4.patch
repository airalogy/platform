+/**
+ * Parse TOML string into a JavaScript object
+ * @param {string} toml - TOML string to parse
+ * @param {object} opts - Options for parsing
+ * @param {boolean} [opts.withLineRanges=false] - Whether to include line ranges in the result
+ * @param {number} [opts.maxDepth=1000] - Maximum depth of nested structures
+ * @returns {object} Parsed TOML data
+ */
+function parse(toml, opts = {}) {
+    const result = parseInternal(toml, opts);
+    
+    // For backward compatibility, return just the data if withLineRanges is not true
+    if (!opts.withLineRanges) {
+        return result.data;
+    }
+    
+    return result;
+}
