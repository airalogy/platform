     }
     return seek;
 }
+
+/**
+ * Calculate line number and column position from a character index in the string
+ * @param {string} str - The string to analyze
+ * @param {number} pos - The character position (index) in the string
+ * @returns {object} An object with line and column properties
+ */
+export function getLineNumberAndColumn(str, pos) {
+    let line = 1;
+    let column = 1;
+    
+    for (let i = 0; i < pos && i < str.length; i++) {
+        if (str[i] === '\n') {
+            line++;
+            column = 1;
+        } else if (str[i] === '\r' && str[i + 1] === '\n') {
+            line++;
+            column = 1;
+            i++; // Skip the \n part
+        } else {
+            column++;
+        }
+    }
+    
+    return { line, column };
+}
